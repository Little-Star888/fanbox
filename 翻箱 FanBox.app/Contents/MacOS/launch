#!/bin/bash
# 翻箱 FanBox 启动器：起本地服务并打开管理页面
PROJECT="/Users/alchain/Documents/_开发项目/fanbox"
URL="http://localhost:4567"
NODE="/opt/homebrew/bin/node"
[ -x "$NODE" ] || NODE="$(command -v node 2>/dev/null)"
[ -x "$NODE" ] || NODE="/usr/local/bin/node"

# 服务已在跑 → 直接开页面
if /usr/bin/nc -z 127.0.0.1 4567 2>/dev/null; then
  /usr/bin/open "$URL"
  exit 0
fi

# 没装 Node → 友好弹窗
if [ ! -x "$NODE" ]; then
  /usr/bin/osascript -e 'display dialog "还没装 Node.js。请到 nodejs.org 下载 LTS 版本装好后，再双击一次翻箱图标即可。" buttons {"好"} default button "好" with title "翻箱 FanBox"'
  exit 1
fi

cd "$PROJECT" || { /usr/bin/osascript -e 'display dialog "没找到 fanbox 项目目录，请确认它在 文档/_开发项目/fanbox。" buttons {"好"}'; exit 1; }
# 起服务（让启动器自己开浏览器，避免开两个标签）
FANBOX_NO_OPEN=1 nohup "$NODE" server.js >/tmp/fanbox.log 2>&1 &
# 等端口就绪再打开
for i in $(seq 1 40); do
  /usr/bin/nc -z 127.0.0.1 4567 2>/dev/null && break
  sleep 0.2
done
/usr/bin/open "$URL"
